<a class="item item-interact" href="/library/{{this.userID}}">

    <div class="item-header">

        <!-- Left side: Game title + username -->
        <div class="item-title-group">
            <div class="item-title">{{this.gameName}}</div>
            <div class="item-subtitle">owned by {{this.username}}</div>
        </div>

        <!-- Right side: actions -->
        <div class="item-actions">
            <div class="item-id">{{this.lgID}}</div>

            <form method="POST" action="/libraryGames/origin/delete/{{this.lgID}}">
                <button type="submit" class="material-symbols-outlined delete">
                    delete
                </button>
            </form>

            <span class="material-symbols-outlined edit">edit</span>
        </div>

    </div>

    <div class="item-details">

        <div class="info-box">
            <span class="label">Playtime</span>
            <span class="label-content">{{this.playtime}}</span>
        </div>

        <div class="info-box">
            <span class="label">Completion</span>
            <span class="label-content">{{this.completion}}</span>
        </div>

    </div>
</a>